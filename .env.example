# Application
NODE_ENV=development
JWT_SECRET=dev-local-jwt-secret-min-32-chars-long

# PostgreSQL
DATABASE_URL=postgres://postgres:secret_password@localhost:5432/velo_db

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_URL=redis://localhost:6379

# Webhook engine
# ENDPOINT_CACHE_TTL_SECONDS=60
# WORKER_CONCURRENCY=10
# ENABLE_EMBEDDED_WORKER=false

# Benchmark (optional)
# RUN_BENCHMARK=true
# BENCHMARK_PROJECT_ID=your-project-uuid
# BENCHMARK_REQUESTS=100
# BENCHMARK_CONCURRENCY=50
